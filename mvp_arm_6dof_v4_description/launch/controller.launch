<launch>

<rosparam file="$(find mvp_arm_6dof_v4_description)/launch/controller.yaml" command="load"/>
<node args="joint_state_controller " name="controller_spawner" ns="mvp_arm_6dof_v4" output="screen" pkg="controller_manager" respawn="false" type="spawner"/>
<node name="robot_state_publisher" output="screen" pkg="robot_state_publisher" respawn="false" type="robot_state_publisher">
  <remap from="/joint_states" to="/mvp_arm_6dof_v4/joint_states"/>
</node>

</launch>